{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MonStock",
  "version": "0.2.0",
  "identifier": "com.monstock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MonStock",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "maximized": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Samir Bettahar",
    "copyright": "Copyright (c) 2026 Samir Bettahar",
    "category": "Business",
    "shortDescription": "Stock management for small businesses",
    "longDescription": "MonStock is a desktop inventory and sales management application built for small businesses in Algeria.",
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/samir1498/MonStock/releases/latest/download/tauri-update.json"
      ]
    }
  }
}